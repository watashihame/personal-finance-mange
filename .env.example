# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# PostgreSQL
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change_me_strong_password

# Flask
SECRET_KEY=change_me_random_secret_key_32chars

# Tushare（A股行情，在 tushare.pro 注册后获取）
TUSHARE_TOKEN=your_tushare_token_here

# Nginx 监听端口（默认 80）
# NGINX_PORT=80

# MCP Server 监听端口（默认 8000，仅 streamable-http 模式使用）
# MCP_PORT=8000
